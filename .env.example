SERVER_HOST="example.com"
LE_EMAIL="admin@example.com"

# Proxmox internal service network.
HOMELAB_BRIDGE="vmbr10"
HOMELAB_NETWORK_PREFIX="10.10.10"
HOMELAB_NETWORK_CIDR="10.10.10.0/24"
HOMELAB_GATEWAY_IP="10.10.10.1"
HOMELAB_DHCP_START="10.10.10.100"
HOMELAB_DHCP_END="10.10.10.200"
HOMELAB_ENABLE_PVE_FIREWALL="true"

# VPN/direct WireGuard ports allowed by Proxmox host firewall setup.
WIREGUARD_PORT="51820"
TAILSCALE_WIREGUARD_PORT="41641"

# LXC IDs and VM IDs.
PROXY_CTID="110"
AUTH_CTID="111"
HEADSCALE_CTID="112"
MAIL_CTID="113"
OPENPANEL_VMID="114"

# Internal service IPs.
PROXY_IP="10.10.10.10"
PROXY_TAILNET_IP=""
AUTH_IP="10.10.10.20"
HEADSCALE_IP="10.10.10.30"
MAIL_IP="10.10.10.40"
OPENPANEL_IP="10.10.10.50"

# Public hostnames routed through Nginx Proxy Manager.
PROXY_DOMAIN="proxy.example.com"
AUTH_DOMAIN="auth.example.com"
HEADSCALE_DOMAIN="headscale.example.com"
HEADPLANE_DOMAIN="headplane.example.com"
OPENPANEL_CLIENT_PANEL_DOMAIN="openpanel.example.com"
OPENPANEL_ADMIN_DOMAIN="openadmin.example.com"
OPENPANEL_PROVISION_VM="true"
OPENPANEL_VM_INSTALL_METHOD="cloud-image"
OPENPANEL_CLOUD_IMAGE_URL="https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-amd64.img"
# Use auto to fuzzy-select the newest Debian/Ubuntu ISO from Proxmox ISO storage.
# Only used when OPENPANEL_VM_INSTALL_METHOD="iso".
OPENPANEL_ISO="auto"
OPENPANEL_ISO_STORAGE="auto"
OPENPANEL_VM_STORAGE="auto"
OPENPANEL_SSH_USER="openpanel"
MAIL_DOMAIN="mail.example.com"
EMAIL_APP_DOMAIN="email.example.com"
WEBMAIL_DOMAIN="webmail.example.com"
LISTMONK_DOMAIN="listmonk.example.com"
POSTAL_DOMAIN="postal.example.com"
LIBREDESK_DOMAIN="libredesk.example.com"
AUTODISCOVER_DOMAIN="autodiscover.example.com"
AUTOCONFIG_DOMAIN="autoconfig.example.com"
MTA_STS_DOMAIN="mta-sts.example.com"

# Initial Authelia file-backed admin user.
AUTH_ADMIN_USER="admin"

# Nginx Proxy Manager credentials.
# The installer seeds NPM's initial admin account with these values.
# Leave NPM_ADMIN_EMAIL empty to use LE_EMAIL.
# Leave NPM_PASSWORD empty to generate one under /root/homelab/secrets/npm-admin-password.
NPM_ADMIN_EMAIL=""
NPM_PASSWORD=""
NPM_VERSION="latest"

# NPM requests Let's Encrypt certs with Cloudflare DNS-01 by default.
# This works even while Cloudflare proxying is enabled. Token needs Zone:DNS:Edit.
# Leave NPM_CLOUDFLARE_DNS_API_TOKEN empty to use CLOUDFLARE_DNS_API_TOKEN,
# then STALWART_ACME_DNS_CF_SECRET as a final fallback.
# Set NPM_SKIP_CLOUDFLARE_DNS_TOKEN=true only to force HTTP-01 instead.
CLOUDFLARE_DNS_API_TOKEN=""
NPM_CLOUDFLARE_DNS_API_TOKEN=""
NPM_DNS_PROPAGATION_SECONDS="60"
NPM_SKIP_CLOUDFLARE_DNS_TOKEN="false"

# Stalwart DNS-01 ACME for the mail LXC. Leave STALWART_ACME_DNS_CF_SECRET
# empty to fall back to CLOUDFLARE_DNS_API_TOKEN in the generated
# /opt/email-service/.env file, or set it here to use a separate token.
EMAIL_SERVICE_REPO="https://github.com/ChibaLLC/email-service"
EMAIL_SERVICE_REF="main"
MAIL_PORTS="25 110 143 465 587 993 995 4190"
STALWART_ACME_ENABLED="true"
STALWART_ACME_DNS_PROVIDER="cloudflare"
STALWART_ACME_DNS_CF_SECRET=""

# Container image versions.
AUTHELIA_VERSION="latest"
HEADSCALE_VERSION="0.28.0"
HEADPLANE_VERSION="latest"

# OpenPanel Community Edition LXC.
# Use "auto" to calculate a portable share while reserving RAM/CPU for the host
# and one manual diagnostic VM.
OPENPANEL_MEMORY_MB="auto"
OPENPANEL_MIN_MEMORY_MB="4096"
OPENPANEL_MAX_MEMORY_MB="16384"
OPENPANEL_HOST_RESERVE_MB="4096"
OPENPANEL_DIAGNOSTIC_VM_RESERVE_MB="8192"
OPENPANEL_CORES="auto"
OPENPANEL_CPU_RESERVE="2"
OPENPANEL_MAX_CORES="8"
OPENPANEL_DISK_GB="120"
OPENPANEL_PUBLIC_BACKEND_PORT="80"
OPENPANEL_CLIENT_PANEL_PORT="2083"
OPENPANEL_CLIENT_PANEL_SCHEME="http"
OPENPANEL_NPM_SYNC_INTERVAL_SECONDS="60"
OPENPANEL_NPM_AUTO_CERTS="true"
OPENPANEL_CLOUDFLARE_DNS_API_TOKEN=""
# Leave target empty to use the Proxmox host public IP detected during setup.
OPENPANEL_CLOUDFLARE_DNS_TARGET=""
# Optional comma-separated allowlist. Empty means all active zones visible to the token.
OPENPANEL_CLOUDFLARE_DNS_ZONES=""
OPENPANEL_CLOUDFLARE_DNS_PROXIED="false"
# Cloudflare automatic TTL is 1. Use a numeric TTL in seconds to override.
OPENPANEL_CLOUDFLARE_DNS_TTL="1"
